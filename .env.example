BOT_TOKEN=123456:telegram-bot-token
GROQ_API_KEY=gsk-your-groq-key
GROQ_BASE_URL=https://api.groq.com

# Telegram numeric IDs separated by comma. Admins are allowed automatically.
ADMIN_TELEGRAM_IDS=123456789
ALLOWED_TELEGRAM_IDS=123456789,987654321

# true = everyone can use the bot; admin rights still belong only to ADMIN_TELEGRAM_IDS.
ALLOW_ALL_USERS=true

# Models are configurable so you can switch without code changes.
GROQ_TEXT_MODEL=qwen/qwen3-32b
VOICE_TRANSCRIBER=t_one
# Local T-one service URL. Docker Compose uses ws://t-one:8080/api/ws by default.
# T_ONE_WS_URL=ws://127.0.0.1:8080/api/ws
T_ONE_CONNECT_TIMEOUT_SECONDS=20
T_ONE_RECEIVE_TIMEOUT_SECONDS=30
T_ONE_FINAL_TIMEOUT_SECONDS=90
T_ONE_TOTAL_TIMEOUT_SECONDS=240
T_ONE_MAX_ATTEMPTS=2
T_ONE_RETRY_DELAY_SECONDS=2
T_ONE_AUDIO_FILTER=highpass=f=80,lowpass=f=3800,dynaudnorm=f=150:g=15
MEDIA_COMMAND_TIMEOUT_SECONDS=180
VOICE_PROCESSING_TIMEOUT_SECONDS=300

DATABASE_PATH=data/ideas.db
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_DIGEST_WEEKDAY=6
DEFAULT_DIGEST_TIME=19:00
SHORT_INPUT_CHAR_LIMIT=900
