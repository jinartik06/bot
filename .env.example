BOT_TOKEN=123456:telegram-bot-token
GROQ_API_KEY=gsk-your-groq-key
GROQ_BASE_URL=https://api.groq.com

# Telegram numeric IDs separated by comma. Admins are allowed automatically.
ADMIN_TELEGRAM_IDS=123456789
ALLOWED_TELEGRAM_IDS=123456789,987654321

# true = everyone can use the bot; admin rights still belong only to ADMIN_TELEGRAM_IDS.
ALLOW_ALL_USERS=true

# Models are configurable so you can switch without code changes.
GROQ_TEXT_MODEL=qwen/qwen3-32b
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_TRANSCRIBE_MODEL=whisper-large-v3-turbo

# faster_whisper runs locally in the bot container and does not need a speech API key.
# You can set VOICE_TRANSCRIBER=groq later if your Groq key supports audio/transcriptions.
VOICE_TRANSCRIBER=faster_whisper
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=2
WHISPER_NUM_WORKERS=1
WHISPER_LANGUAGE=ru
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=false
WHISPER_MODEL_CACHE_DIR=models
VOICE_LOCK_WAIT_SECONDS=180
VOICE_LOCK_TTL_SECONDS=600
FFMPEG_BINARY=ffmpeg
MEDIA_COMMAND_TIMEOUT_SECONDS=180
VOICE_PROCESSING_TIMEOUT_SECONDS=300

# Photos are stored locally; OCR uses Tesseract when it is installed.
PHOTO_STORAGE_DIR=data/photos
PHOTO_OCR_ENABLED=true
TESSERACT_BINARY=tesseract
PHOTO_OCR_LANGUAGE=rus+eng
PHOTO_OCR_TIMEOUT_SECONDS=30
PHOTO_VISION_ENABLED=true
PHOTO_VISION_TIMEOUT_SECONDS=60

DATABASE_PATH=data/ideas.db
DEFAULT_TIMEZONE=Europe/Moscow
DEFAULT_DIGEST_WEEKDAY=6
DEFAULT_DIGEST_TIME=19:00
SHORT_INPUT_CHAR_LIMIT=900
